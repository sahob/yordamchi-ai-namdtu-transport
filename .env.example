APP_NAME="Yordamchi AI — NamDTU Transport fakulteti"
APP_VERSION="0.2.0-rag"
ENVIRONMENT=local

# Ixtiyoriy savolga AI javob berishi uchun majburiy:
OPENAI_API_KEY=

# OpenAI hisobingizda mavjud modelni yozing.
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

KNOWLEDGE_BASE_DIR=knowledge_base
MAX_CONTEXT_CHUNKS=8
MIN_KEYWORD_SCORE=0.03
MIN_VECTOR_SCORE=0.20
USE_VECTOR_SEARCH=true
VECTOR_INDEX_PATH=.cache/vector_index.json
